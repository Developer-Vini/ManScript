    # Colisao item 3
    let ddx = px + 40 - i3x
    let ddy = py + 20 - i3y
    if (ddx < 0)
    begin
        let ddx = 0 - ddx
    end
    if (ddy < 0)
    begin
        let ddy = 0 - ddy
    end
    if (ddx < 45)
    begin
        if (ddy < 25)
        begin
            if (i3tipo == 1)
            begin
                let pontos = pontos + 10
            end
            if (i3tipo == 0)
            begin
                let vidas = vidas - 1
            end
            let i3y = 0 - 20
            let i3x = rand(20, 760)
            let i3tipo = rand(0, 1)
        end
    end

    # Colisao item 4
    let ddx = px + 40 - i4x
    let ddy = py + 20 - i4y
    if (ddx < 0)
    begin
        let ddx = 0 - ddx
    end
    if (ddy < 0)
    begin
        let ddy = 0 - ddy
    end
    if (ddx < 45)
    begin
        if (ddy < 25)
        begin
            if (i4tipo == 1)
            begin
                let pontos = pontos + 10
            end
            if (i4tipo == 0)
            begin
                let vidas = vidas - 1
            end
            let i4y = 0 - 20
            let i4x = rand(20, 760)
            let i4tipo = rand(0, 1)
        end
    end

    # Colisao item 5
    let ddx = px + 40 - i5x
    let ddy = py + 20 - i5y
    if (ddx < 0)
    begin
        let ddx = 0 - ddx
    end
    if (ddy < 0)
    begin
        let ddy = 0 - ddy
    end
    if (ddx < 45)
    begin
        if (ddy < 25)
        begin
            if (i5tipo == 1)
            begin
                let pontos = pontos + 10
            end
            if (i5tipo == 0)
            begin
                let vidas = vidas - 1
            end
            let i5y = 0 - 20
            let i5x = rand(20, 760)
            let i5tipo = rand(0, 1)
        end
    end

    if (vidas < 1)
    begin
        let rodando = 0
    end

    # Desenha item 1
    if (i1tipo == 1)
    begin
        color(255, 220, 40)
        circle(i1x, i1y, 14)
        color(255, 255, 150)
        circle(i1x - 3, i1y - 3, 5)
    end
    if (i1tipo == 0)
    begin
        color(180, 60, 60)
        circle(i1x, i1y, 14)
        color(255, 255, 255)
        circle(i1x - 4, i1y - 3, 4)
        circle(i1x + 4, i1y - 3, 4)
        color(180, 60, 60)
        circle(i1x - 4, i1y - 3, 2)
        circle(i1x + 4, i1y - 3, 2)
        color(255, 255, 255)
        line(i1x - 5, i1y + 4, i1x + 5, i1y + 4)
    end

    # Desenha item 2
    if (i2tipo == 1)
    begin
        color(255, 220, 40)
        circle(i2x, i2y, 14)
        color(255, 255, 150)
        circle(i2x - 3, i2y - 3, 5)
    end
    if (i2tipo == 0)
    begin
        color(180, 60, 60)
        circle(i2x, i2y, 14)
        color(255, 255, 255)
        circle(i2x - 4, i2y - 3, 4)

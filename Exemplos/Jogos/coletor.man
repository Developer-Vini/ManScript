let px = 360
let py = 510
let pvel = 6
let pontos = 0
let vidas = 5
let rodando = 1

# Itens que caem
let i1x = rand(20, 760)
let i1y = 0 - 20
let i1tipo = 1
let i1vel = 4

let i2x = rand(20, 760)
let i2y = 0 - 100
let i2tipo = 0
let i2vel = 5

let i3x = rand(20, 760)
let i3y = 0 - 200
let i3tipo = 1
let i3vel = 3

let i4x = rand(20, 760)
let i4y = 0 - 300
let i4tipo = 0
let i4vel = 6

let i5x = rand(20, 760)
let i5y = 0 - 400
let i5tipo = 1
let i5vel = 5

while (rodando == 1)
begin
    bgcolor(10, 10, 30)
    clear

    # Ceu estrelado
    color(30, 30, 70)
    rect(0, 0, 800, 600)
    color(180, 180, 255)
    circle(80, 40, 1)
    circle(200, 80, 1)
    circle(400, 20, 1)
    circle(600, 60, 1)
    circle(720, 30, 1)
    circle(150, 150, 1)
    circle(550, 120, 1)

    # Chao
    color(40, 30, 20)
    rect(0, 555, 800, 45)
    color(60, 50, 30)
    rect(0, 555, 800, 8)

    # Teclado
    key(tecla)
    if (tecla == "left")
    begin
        let px = px - pvel
    end
    if (tecla == "right")
    begin
        let px = px + pvel
    end
    if (px < 0)
    begin
        let px = 0
    end
    if (px > 720)
    begin
        let px = 720
    end

    # Move itens
    let i1y = i1y + i1vel
    let i2y = i2y + i2vel
    let i3y = i3y + i3vel
    let i4y = i4y + i4vel
    let i5y = i5y + i5vel

    # Reseta itens que saem da tela
    if (i1y > 560)
    begin
        let i1y = 0 - 20
        let i1x = rand(20, 760)
        let i1tipo = rand(0, 1)
    end
    if (i2y > 560)
    begin
        let i2y = 0 - 20
        let i2x = rand(20, 760)
        let i2tipo = rand(0, 1)
    end
    if (i3y > 560)
    begin
        let i3y = 0 - 20
        let i3x = rand(20, 760)
        let i3tipo = rand(0, 1)
    end
    if (i4y > 560)
    begin
        let i4y = 0 - 20
        let i4x = rand(20, 760)
        let i4tipo = rand(0, 1)
    end
    if (i5y > 560)
    begin
        let i5y = 0 - 20
        let i5x = rand(20, 760)
        let i5tipo = rand(0, 1)
    end

    # Colisao item 1
    let ddx = px + 40 - i1x
    let ddy = py + 20 - i1y
    if (ddx < 0)
    begin
        let ddx = 0 - ddx
    end
    if (ddy < 0)
    begin
        let ddy = 0 - ddy
    end
    if (ddx < 45)
    begin
        if (ddy < 25)
        begin
            if (i1tipo == 1)
            begin
                let pontos = pontos + 10
            end
            if (i1tipo == 0)
            begin
                let vidas = vidas - 1
            end
            let i1y = 0 - 20
            let i1x = rand(20, 760)
            let i1tipo = rand(0, 1)
        end
    end

    # Colisao item 2
    let ddx = px + 40 - i2x
    let ddy = py + 20 - i2y
    if (ddx < 0)
    begin
        let ddx = 0 - ddx
    end
    if (ddy < 0)
    begin
        let ddy = 0 - ddy
    end
    if (ddx < 45)
    begin
        if (ddy < 25)
        begin
            if (i2tipo == 1)
            begin
                let pontos = pontos + 10
            end
            if (i2tipo == 0)
            begin
                let vidas = vidas - 1
            end
            let i2y = 0 - 20
            let i2x = rand(20, 760)
            let i2tipo = rand(0, 1)
        end

    end
    if (i4tipo == 0)
    begin
        color(180, 60, 60)
        circle(i4x, i4y, 14)
        color(255, 255, 255)
        circle(i4x - 4, i4y - 3, 4)
        circle(i4x + 4, i4y - 3, 4)
        color(180, 60, 60)
        circle(i4x - 4, i4y - 3, 2)
        circle(i4x + 4, i4y - 3, 2)
        color(255, 255, 255)
        line(i4x - 5, i4y + 4, i4x + 5, i4y + 4)
    end

    # Desenha item 5
    if (i5tipo == 1)
    begin
        color(255, 220, 40)
        circle(i5x, i5y, 14)
        color(255, 255, 150)
        circle(i5x - 3, i5y - 3, 5)
    end
    if (i5tipo == 0)
    begin
        color(180, 60, 60)
        circle(i5x, i5y, 14)
        color(255, 255, 255)
        circle(i5x - 4, i5y - 3, 4)
        circle(i5x + 4, i5y - 3, 4)
        color(180, 60, 60)
        circle(i5x - 4, i5y - 3, 2)
        circle(i5x + 4, i5y - 3, 2)
        color(255, 255, 255)
        line(i5x - 5, i5y + 4, i5x + 5, i5y + 4)
    end

    # Cesto (player)
    color(160, 100, 40)
    rect(px, py, 80, 10)
    rect(px, py, 8, 40)
    rect(px + 72, py, 8, 40)
    color(200, 140, 60)
    rect(px + 2, py + 2, 76, 6)

    # Vidas como coracoes
    color(255, 80, 80)
    let hx = 10
    let hi = 0
    while (hi < vidas)
    begin
        circle(hx, 575, 8)
        let hx = hx + 22
        let hi = hi + 1
    end

    # HUD
    color(255, 220, 50)
    text(340, 568, 18, "PONTOS:")
    color(255, 255, 255)
    text(445, 568, 18, str(pontos))

    render
    sleep(16)
end

bgcolor(10, 10, 30)
clear
color(20, 20, 60)
rect(0, 0, 800, 600)
color(255, 80, 80)
text(230, 200, 48, "GAME OVER")
color(255, 220, 50)
text(220, 300, 28, "Pontuacao final:")
color(255, 255, 255)
text(460, 300, 28, str(pontos))
color(180, 100, 100)
text(200, 380, 18, "Pegou caveiras demais!")
color(100, 100, 150)
text(240, 430, 16, "Feche a janela para sair")

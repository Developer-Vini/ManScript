fun can_walk(x, y) {
    return !blocked(floor(x), floor(y));
}

fun make_npc(x, y, kind) {
    let hp = 100;
    if (kind == 1) { hp = 150; }
    if (kind == 2) { hp = 350; }
    return {x: x, y: y, kind: kind, hp: hp, alive: true, pain: false, awake: false, attack_t: 0, death_frame: 0, path_t: 0, path_x: x, path_y: y};
}

fun spawn_npcs() {
    npcs = [];
    let count = 0;
    while (count < 20) {
        let x = rand_int(MAP_W);
        let y = rand_int(MAP_H);
        let tries = 0;
        while ((blocked(x, y) or (x < 10 and y < 10)) and tries < 300) {
            x = rand_int(MAP_W);
            y = rand_int(MAP_H);
            tries++;
        }
        if (!blocked(x, y) and !(x < 10 and y < 10)) {
            let roll = rand_int(100);
            let kind = 0;
            if (roll >= 70 and roll < 90) { kind = 1; }
            if (roll >= 90) { kind = 2; }
            push(npcs, make_npc(x + 0.5, y + 0.5, kind));
            count++;
        } else {
            count = 20;
        }
    }
}


fun map_at(x, y) {
    if (x < 0 or y < 0 or x >= MAP_W or y >= MAP_H) { return 1; }
    return MAP[y * MAP_W + x];
}

fun blocked(x, y) {
    return map_at(x, y) != 0;
}

fun angle_norm(a) {
    while (a < 0) { a += TWO_PI; }
    while (a >= TWO_PI) { a -= TWO_PI; }
    return a;
}

fun angle_diff(a) {
    while (a > 3.14159) { a -= TWO_PI; }
    while (a < -3.14159) { a += TWO_PI; }
    return a;
}


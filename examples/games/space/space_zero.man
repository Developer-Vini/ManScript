let state = "title";
let tick = 0;
let score = 0;
let space_lock = false;
let r_lock = false;

init_stars();

while (running()) {
    poll();
    if (key("Escape")) { quit(); }
    tick++;

    if (state == "title") {
        draw_bg(tick);
        draw_stars(tick);

        let dy = sin(tick * 0.04) * 8;
        let fp = {x: W/2 - 20, y: 500 + floor(dy), w: 40, h: 38, hp: 5, max_hp: 5};
        invincible = 0;
        draw_player(fp);
        color(180, 255, 255);
        rect(W/2 - 2, 480 + floor(dy), 4, 14);
        color(80, 200, 255);
        rect(W/2 - 1, 470 + floor(dy), 2, 8);

        draw_title();

        if (key("Space") and !space_lock) {
            state = "wave_start";
            wave = 1;
            score = 0;
            player.hp = player.max_hp;
            player.x = W/2 - 20;
            player.y = H - 110;
            bullets = [];
            enemy_bullets = [];
            enemies = [];
            particles = [];
            wave_timer = 0;
            wave_spawned = false;
            space_lock = true;
        }
        if (!key("Space")) { space_lock = false; }
    }

    if (state == "wave_start") {
        draw_bg(tick);
        draw_stars(tick);
        draw_player(player);
        draw_wave_banner(wave);
        wave_timer++;
        if (!wave_spawned) {
            spawn_wave(wave);
            wave_spawned = true;
        }
        if (wave_timer > 90) {
            state = "play";
            wave_timer = 0;
        }
    }

    if (state == "play") {
        if (key("Left") or key("A")) { player.x -= player.speed; }
        if (key("Right") or key("D")) { player.x += player.speed; }
        if (key("Up") or key("W")) { player.y -= player.speed; }
        if (key("Down") or key("S")) { player.y += player.speed; }
        player.x = clamp(player.x, 0, W - player.w);
        player.y = clamp(player.y, 60, H - player.h - 40);

        shoot_timer++;
        if (key("Space") and shoot_timer >= shoot_cd) {
            shoot(player.x + player.w/2 - 2, player.y);
            shoot_timer = 0;
        }

        if (invincible > 0) { invincible--; }

        update_bullets();
        update_enemy_bullets();
        update_enemies(tick);
        update_particles();

        let bi = 0;
        while (bi < len(bullets)) {
            let b = bullets[bi];
            let hit_any = false;
            let ei = 0;
            while (ei < len(enemies)) {
                let e = enemies[ei];
                if (aabb(b.x - 2, b.y, b.w, b.h, e.x, e.y, e.w, e.h)) {
                    e.hp--;
                    if (e.tipo == 0) { spawn_explosion(e.x + e.w/2, e.y + e.h/2, 255, 80, 200); }
                    if (e.tipo == 1) { spawn_explosion(e.x + e.w/2, e.y + e.h/2, 255, 180, 30); }
                    if (e.tipo == 2) { spawn_explosion(e.x + e.w/2, e.y + e.h/2, 60, 200, 255); }
                    if (e.hp <= 0) {
                        if (e.tipo == 0) { score += 10; }
                        if (e.tipo == 1) { score += 15; }
                        if (e.tipo == 2) { score += 40; spawn_explosion(e.x + e.w/2, e.y + e.h/2, 60, 200, 255); }
                        remove(enemies, ei);
                    } else {
                        ei++;
                    }
                    hit_any = true;
                    break;
                }
                ei++;
            }
            if (hit_any) {
                remove(bullets, bi);
            } else {
                bi++;
            }
        }

        if (invincible <= 0) {
            let ebi = 0;
            while (ebi < len(enemy_bullets)) {
                let eb = enemy_bullets[ebi];
                if (aabb(eb.x - 3, eb.y, eb.w, eb.h, player.x, player.y, player.w, player.h)) {
                    player.hp--;
                    spawn_explosion(player.x + player.w/2, player.y + player.h/2, 60, 180, 255);
                    invincible = 80;
                    remove(enemy_bullets, ebi);
                    if (player.hp <= 0) {
                        spawn_explosion(player.x + player.w/2, player.y + player.h/2, 60, 180, 255);
                        spawn_explosion(player.x + player.w/2, player.y, 255, 255, 200);
                        state = "gameover";
                    }
                } else {
                    ebi++;
                }
            }
        }

        if (invincible <= 0) {
            let ei2 = 0;
            while (ei2 < len(enemies)) {
                let e = enemies[ei2];
                if (aabb(e.x, e.y, e.w, e.h, player.x + 4, player.y + 4, player.w - 8, player.h - 8)) {
                    player.hp--;
                    spawn_explosion(player.x + player.w/2, player.y + player.h/2, 60, 180, 255);
                    invincible = 80;
                    if (player.hp <= 0) {
                        state = "gameover";
                    }
                }
                ei2++;
            }
        }

        if (len(enemies) == 0 and state == "play") {
            wave++;
            wave_spawned = false;
            wave_timer = 0;
            state = "wave_start";
        }

        draw_bg(tick);
        draw_stars(tick);
        draw_enemies();
        draw_player(player);
        draw_bullets();
        draw_enemy_bullets();
        draw_particles();
        draw_hud(score, wave);
    }

    if (state == "gameover") {
        update_particles();
        draw_bg(tick);
        draw_stars(tick);
        draw_particles();
        draw_gameover(score);

        if (key("R") and !r_lock) {
            state = "title";
            bullets = [];
            enemy_bullets = [];
            enemies = [];
            particles = [];
            player.hp = player.max_hp;
            r_lock = true;
        }
        if (!key("R")) { r_lock = false; }
    }

    present();
    delay(16);
}

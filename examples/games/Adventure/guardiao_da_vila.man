fun add_prop(sprite, x, y, w, h, bx, by, bw, bh) {
    push(props, {sprite: sprite, x: x, y: y, w: w, h: h, bx: bx, by: by, bw: bw, bh: bh});
}

fun add_coin(x, y) {
    push(coins, {x: x, y: y, kind: 0, got: false});
}

fun add_enemy(kind, x, y, home_x, home_y) {
    push(enemies, {kind: kind, x: x, y: y, hp: 2 + kind, alive: true, home_x: home_x, home_y: home_y, hit: 0, phase: rand(80)});
}

